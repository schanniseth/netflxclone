TMDB_API_KEY=your_tmdb_api_key_here
DEBUG=True
SECRET_KEY=change-me-in-production

# Leave unset locally to use the bundled db.sqlite3. In production (e.g. on
# Vercel), set this to a Postgres connection string — Vercel Postgres/Neon/
# Supabase all set this automatically when attached as an integration.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Email / password reset (defaults to printing emails to the console, so
# "forgot password" works with zero setup in development).
# For production, switch to the SMTP backend and fill in real credentials:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=Netflex <no-reply@netflex.example>
